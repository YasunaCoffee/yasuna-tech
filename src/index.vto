---
layout: layouts/base.vto
bodyClass: body-home
title: Home
---

<header class="page-header page-header--home">
  <h1 class="sr-only">{{ metas.site }}</h1>
  <div class="home-hero home-hero--profile">
    {{ if it.site_icon }}
    <img
      src="{{ it.site_icon }}"
      alt=""
      class="home-avatar"
      width="80"
      height="80"
      decoding="async"
    />
    {{ /if }}
    <nav class="home-profile" aria-label="プロフィール・外部リンク">
      <div class="home-profile-row">
        {{ if home.tagline }}
        <p class="home-profile-tagline">{{ home.tagline }}</p>
        {{ /if }}
        <ul class="home-profile-links">
          {{ for link of home.profile_links }}
          <li>
            <a
              class="home-profile-icon-link"
              href="{{ link.href }}"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="{{ link.label }}"
            >
              {{ include "partials/home-sns-icon.vto" { icon: link.icon } }}
            </a>
          </li>
          {{ /for }}
        </ul>
      </div>
      {{ if home.profile_intro_links?.length }}
      <p class="home-profile-intro">
        {{ for link of home.profile_intro_links }}
        <a class="home-profile-intro-link" href="{{ link.href }}">{{ link.label }}</a>
        {{ /for }}
      </p>
      {{ /if }}
    </nav>
  </div>
</header>

<section class="post-grid" aria-label="記事一覧">
  {{ for post of search.pages("type=post", "lastUpdated=desc") }}
  <article class="post-card">
    <a href="{{ post.url }}" class="post-card-link">
      <img
        class="post-card-thumb"
        src="{{ post.basename |> thumbUrl }}"
        alt=""
        width="960"
        height="540"
        loading="lazy"
        decoding="async"
      />
      <span class="sr-only">{{ post.title }}</span>
    </a>
  </article>
  {{ /for }}
</section>

<p class="home-archive-link"><a href="/archive/">アーカイブ（タグ・一覧）</a></p>
